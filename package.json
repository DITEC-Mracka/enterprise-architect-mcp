{
  "name": "enterprise-architect-mcp",
  "version": "1.0.0",
  "description": "MCP server for read-only access to Sparx Enterprise Architect .qea exports",
  "type": "module",
  "bin": {
    "mcp-server-ea": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node -p \"'export const packageVersion = ' + JSON.stringify(require('./package.json').version) + ';\\n'\" > src/version.ts",
    "build": "tsc",
    "precommit": "npm run build",
    "watch": "tsc --watch",
    "test": "jest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "fast-xml-parser": "^5.2.3",
    "yargs": "^17.7.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.31",
    "@types/yargs": "^17.0.33",
    "jest": "^29.7.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  }
}
